{
  "name": "orbitblocker-extension",
  "private": true,
  "type": "module",
  "scripts": {
    "build:icons": "powershell -ExecutionPolicy Bypass -File scripts/generate-icons.ps1",
    "build:easyprivacy": "node scripts/build-easyprivacy-rules.mjs",
    "build:rules": "npm run build:easyprivacy",
    "build:assets": "npm run build:icons",
    "validate:release": "node scripts/validate-release.mjs",
    "build:release": "npm run validate:release && powershell -ExecutionPolicy Bypass -File scripts/package-release.ps1"
  }
}